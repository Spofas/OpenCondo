generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Authentication ──────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  emailVerified  DateTime?
  passwordHash          String?
  passwordResetToken    String?   @unique
  passwordResetExpiresAt DateTime?
  phone          String?
  nif            String?
  image          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships         Membership[]
  ownedUnits          Unit[]           @relation("UnitOwner")
  tenantUnits         Unit[]           @relation("UnitTenant")
  announcements       Announcement[]
  maintenanceRequests MaintenanceRequest[]
  announcementReads   AnnouncementRead[]
  meetingAttendances  MeetingAttendee[]
  ataApprovals        AtaApproval[]
  accounts            Account[]
  sessions            Session[]
  usedInvites         Invite[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Condominium ─────────────────────────────────────────────────────────────

enum QuotaModel {
  PERMILAGEM
  EQUAL
}

model Condominium {
  id               String     @id @default(cuid())
  name             String
  address          String
  postalCode       String?
  city             String?
  nif              String?
  totalPermilagem  Int        @default(1000)
  quotaModel       QuotaModel @default(PERMILAGEM)
  fiscalYearStart  Int        @default(1) // month (1 = January)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  units               Unit[]
  memberships         Membership[]
  budgets             Budget[]
  expenses            Expense[]
  quotas              Quota[]
  announcements       Announcement[]
  maintenanceRequests MaintenanceRequest[]
  documents           Document[]
  meetings            Meeting[]
  contracts           Contract[]
  suppliers           Supplier[]
  invites             Invite[]
  recurringExpenses   RecurringExpense[]
}

// ─── Membership (User <-> Condominium) ───────────────────────────────────────

enum Role {
  ADMIN
  OWNER
  TENANT
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  condominiumId  String
  role           Role
  isActive       Boolean      @default(true)
  joinedAt       DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  condominium  Condominium  @relation(fields: [condominiumId], references: [id], onDelete: Cascade)

  @@unique([userId, condominiumId])
}

// ─── Invites ─────────────────────────────────────────────────────────────────

model Invite {
  id             String       @id @default(cuid())
  condominiumId  String
  email          String?      // optional — if set, only that email can use the invite
  role           Role         @default(OWNER)
  token          String       @unique @default(cuid())
  usedAt         DateTime?
  usedByUserId   String?
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  condominium  Condominium  @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  usedByUser   User?        @relation(fields: [usedByUserId], references: [id], onDelete: SetNull)
}

// ─── Units (Frações) ─────────────────────────────────────────────────────────

model Unit {
  id             String       @id @default(cuid())
  condominiumId  String
  identifier     String       // e.g., "1.º Esq", "R/C Dto"
  floor          Int?         // 0 = R/C, 1 = 1.º, -1 = cave, etc.
  typology       String?      // e.g., "T2", "T3"
  permilagem     Int          @default(0)
  sortOrder      Int          @default(0)
  ownerId        String?
  tenantId       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  condominium  Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  owner        User?       @relation("UnitOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  tenant       User?       @relation("UnitTenant", fields: [tenantId], references: [id], onDelete: SetNull)
  quotas       Quota[]
  votes        Vote[]

  @@unique([condominiumId, identifier])
}

// ─── Financial: Budgets ──────────────────────────────────────────────────────

enum BudgetStatus {
  DRAFT
  APPROVED
}

model Budget {
  id                    String       @id @default(cuid())
  condominiumId         String
  year                  Int
  status                BudgetStatus @default(DRAFT)
  totalAmount           Decimal      @db.Decimal(12, 2)
  reserveFundPercentage Decimal      @default(10) @db.Decimal(5, 2)
  approvedAt            DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  condominium  Condominium  @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  items        BudgetItem[]

  @@unique([condominiumId, year])
}

model BudgetItem {
  id             String   @id @default(cuid())
  budgetId       String
  category       String
  description    String?
  plannedAmount  Decimal  @db.Decimal(12, 2)

  budget   Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  expenses Expense[]
}

// ─── Financial: Quotas ───────────────────────────────────────────────────────

enum QuotaStatus {
  PENDING
  PAID
  OVERDUE
}

enum PaymentMethod {
  TRANSFERENCIA
  NUMERARIO
  CHEQUE
  MBWAY
  MULTIBANCO
  OUTRO
}

model Quota {
  id              String        @id @default(cuid())
  condominiumId   String
  unitId          String
  period          String        // e.g., "2026-01", "2026-Q1"
  amount          Decimal       @db.Decimal(12, 2)
  dueDate         DateTime
  status          QuotaStatus   @default(PENDING)
  paymentDate     DateTime?
  paymentMethod   PaymentMethod?
  paymentNotes    String?
  receiptUrl      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  condominium  Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  unit         Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([condominiumId, unitId, period])
  @@index([condominiumId, status])
  @@index([condominiumId, status, dueDate])
}

// ─── Financial: Expenses ─────────────────────────────────────────────────────

model Expense {
  id             String    @id @default(cuid())
  condominiumId  String
  date           DateTime
  description    String
  amount         Decimal   @db.Decimal(12, 2)
  category       String
  supplierId     String?
  budgetItemId   String?
  invoiceUrl     String?
  isRecurring    Boolean   @default(false)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  condominium  Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  supplier     Supplier?   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  budgetItem   BudgetItem? @relation(fields: [budgetItemId], references: [id], onDelete: SetNull)

  @@index([condominiumId, date])
}

// ─── Financial: Recurring Expenses ──────────────────────────────────────────

model RecurringExpense {
  id             String           @id @default(cuid())
  condominiumId  String
  description    String
  amount         Decimal          @db.Decimal(12, 2)
  category       String
  frequency      PaymentFrequency @default(MENSAL)
  isActive       Boolean          @default(true)
  lastGenerated  String?          // period string e.g. "2026-03" (last generated month)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  condominium Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
}

// ─── Communication: Announcements ────────────────────────────────────────────

enum AnnouncementCategory {
  GERAL
  OBRAS
  MANUTENCAO
  ASSEMBLEIA
  URGENTE
}

model Announcement {
  id             String               @id @default(cuid())
  condominiumId  String
  authorId       String
  title          String
  body           String
  category       AnnouncementCategory @default(GERAL)
  pinned         Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  condominium  Condominium        @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  author       User               @relation(fields: [authorId], references: [id])
  reads        AnnouncementRead[]
  attachments  AnnouncementAttachment[]

  @@index([condominiumId, createdAt])
}

model AnnouncementAttachment {
  id              String @id @default(cuid())
  announcementId  String
  fileName        String
  fileUrl         String
  fileSize        Int?

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
}

model AnnouncementRead {
  id              String   @id @default(cuid())
  announcementId  String
  userId          String
  readAt          DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

// ─── Communication: Maintenance Requests ─────────────────────────────────────

enum MaintenanceStatus {
  SUBMETIDO
  EM_ANALISE
  EM_CURSO
  CONCLUIDO
}

enum MaintenancePriority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model MaintenanceRequest {
  id             String              @id @default(cuid())
  condominiumId  String
  requesterId    String
  title          String
  description    String
  location       String?
  priority       MaintenancePriority @default(MEDIA)
  status         MaintenanceStatus   @default(SUBMETIDO)
  supplierId     String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  condominium  Condominium          @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  requester    User                 @relation(fields: [requesterId], references: [id])
  supplier     Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  updates      MaintenanceUpdate[]
  photos       MaintenancePhoto[]

  @@index([condominiumId, status])
}

model MaintenanceUpdate {
  id                   String            @id @default(cuid())
  maintenanceRequestId String
  status               MaintenanceStatus
  note                 String?
  createdAt            DateTime          @default(now())

  maintenanceRequest MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
}

model MaintenancePhoto {
  id                   String @id @default(cuid())
  maintenanceRequestId String
  fileUrl              String
  fileName             String?

  maintenanceRequest MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
}

// ─── Documents ───────────────────────────────────────────────────────────────

enum DocumentCategory {
  ATAS
  ORCAMENTOS
  SEGUROS
  CONTRATOS
  REGULAMENTOS
  OUTROS
}

enum DocumentVisibility {
  ALL
  ADMIN_ONLY
}

model Document {
  id             String             @id @default(cuid())
  condominiumId  String
  name           String
  category       DocumentCategory   @default(OUTROS)
  fileUrl        String
  fileName       String
  fileSize       Int?
  visibility     DocumentVisibility @default(ALL)
  version        Int                @default(1)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  condominium Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
}

// ─── Meetings (Assembleias) ──────────────────────────────────────────────────

enum MeetingType {
  ORDINARIA
  EXTRAORDINARIA
}

enum MeetingStatus {
  AGENDADA
  REALIZADA
  CANCELADA
}

model Meeting {
  id             String        @id @default(cuid())
  condominiumId  String
  date           DateTime
  location       String
  type           MeetingType   @default(ORDINARIA)
  status         MeetingStatus @default(AGENDADA)
  convocatoriaUrl String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  condominium  Condominium      @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  agendaItems  AgendaItem[]
  attendees    MeetingAttendee[]
  ata          Ata?
  votes        Vote[]

  @@index([condominiumId, status])
  @@index([condominiumId, date])
}

model AgendaItem {
  id          String @id @default(cuid())
  meetingId   String
  order       Int
  title       String
  description String?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  votes   Vote[]
}

enum AttendeeStatus {
  PRESENTE
  REPRESENTADO
  AUSENTE
}

model MeetingAttendee {
  id            String         @id @default(cuid())
  meetingId     String
  userId        String
  status        AttendeeStatus @default(AUSENTE)
  permilagem    Int            @default(0)
  representedBy String?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
}

// ─── Atas (Minutes) ──────────────────────────────────────────────────────────

enum AtaStatus {
  RASCUNHO
  FINAL
}

model Ata {
  id        String    @id @default(cuid())
  meetingId String    @unique
  number    Int
  content   String
  status    AtaStatus @default(RASCUNHO)
  pdfUrl    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  meeting   Meeting       @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  approvals AtaApproval[]
}

enum ApprovalStatus {
  PENDENTE
  APROVADO
  CONTESTADO
}

model AtaApproval {
  id        String         @id @default(cuid())
  ataId     String
  userId    String
  status    ApprovalStatus @default(PENDENTE)
  comment   String?
  createdAt DateTime       @default(now())

  ata  Ata  @relation(fields: [ataId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([ataId, userId])
}

// ─── Voting ──────────────────────────────────────────────────────────────────

enum VoteValue {
  A_FAVOR
  CONTRA
  ABSTENCAO
}

model Vote {
  id           String    @id @default(cuid())
  meetingId    String
  agendaItemId String
  unitId       String
  vote         VoteValue
  permilagem   Int       @default(0)
  createdAt    DateTime  @default(now())

  meeting    Meeting    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  agendaItem AgendaItem @relation(fields: [agendaItemId], references: [id], onDelete: Cascade)
  unit       Unit       @relation(fields: [unitId], references: [id])

  @@unique([meetingId, agendaItemId, unitId])
}

// ─── Contracts ───────────────────────────────────────────────────────────────

enum ContractStatus {
  ATIVO
  EXPIRADO
  RENOVADO
  CANCELADO
}

enum RenewalType {
  AUTOMATICA
  MANUAL
}

enum PaymentFrequency {
  MENSAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
  PONTUAL
}

model Contract {
  id               String           @id @default(cuid())
  condominiumId    String
  supplierId       String?
  description      String
  type             String           // e.g., "Limpeza", "Elevador", "Seguro"
  startDate        DateTime
  endDate          DateTime?
  renewalType      RenewalType      @default(MANUAL)
  annualCost       Decimal?         @db.Decimal(12, 2)
  paymentFrequency PaymentFrequency @default(ANUAL)
  status           ContractStatus   @default(ATIVO)
  documentUrl      String?
  policyNumber     String?          // insurance-specific
  insuredValue     Decimal?         @db.Decimal(12, 2)
  coverageType     String?          // insurance-specific
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  condominium Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  supplier    Supplier?   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
}

// ─── Suppliers (Fornecedores) ────────────────────────────────────────────────

model Supplier {
  id             String  @id @default(cuid())
  condominiumId  String
  name           String
  nif            String?
  phone          String?
  email          String?
  category       String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  condominium         Condominium          @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  expenses            Expense[]
  contracts           Contract[]
  maintenanceRequests MaintenanceRequest[]
}

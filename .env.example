# Database
DATABASE_URL="postgresql://user:password@localhost:5432/opencondo?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"   # In production: https://opencondo.app
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="OpenCondo <noreply@opencondo.app>"

# File Storage (S3-compatible)
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
S3_REGION="eu-west-1"
